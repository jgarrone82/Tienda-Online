# ===========================================
# Tienda Online - Variables de Entorno
# ===========================================
# Copiá este archivo a .env y completá los valores reales.
# NUNCA commitees el archivo .env al repositorio.

# MongoDB
MONGODB_URI=mongodb://localhost/tienda_db

# JWT - Usá una cadena larga y random en producción
# Ejemplo: openssl rand -base64 32
JWT_SECRET=tu_jwt_secret_aqui

# Puerto del servidor
PORT=4000
